# API
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=craftworld_unsigned

# Paystack
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_key_here

# Socket.io
VITE_SOCKET_URL=http://localhost:5000

# App
VITE_APP_NAME=CraftworldCentre
VITE_APP_URL=http://localhost:3000

# ── Sprint 3 additions ──────────────────────────────
# Paystack public key (safe to expose — secret key is backend-only)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTE: NEVER put your Paystack SECRET key here. Secret key goes in backend .env only.
